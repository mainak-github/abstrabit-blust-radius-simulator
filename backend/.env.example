# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default for local dev — zero external dependencies):
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (for production — switch provider in prisma/schema.prisma to "postgresql"):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/blast_radius"

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express + Socket.IO server listens on.
PORT=4000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origin of the Next.js frontend. Must match exactly (no trailing slash).
# Local dev:
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://your-domain.com
